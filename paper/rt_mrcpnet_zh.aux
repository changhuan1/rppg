\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces UBFC-Phys subject-independent 统一协议下的对比实验。ACC 表示准确率，AUC 表示受试者工作特征曲线下面积，RGB 表示红绿蓝颜色通道。所有模型均只使用人脸 RGB 视频，并采用相同片段长度、相同训练/验证/测试划分和相同评价代码。所有指标均以百分比（\%）报告。}}{11}{}\protected@file@percent }
