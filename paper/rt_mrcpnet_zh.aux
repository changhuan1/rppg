\newlabel{fig:region_signal_diversity_zh}{{3}{11}{}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces 注意力可靠性可视化。该图展示 RT-MRCPNet 在代表性片段上的时间注意力和区域注意力分布，用于观察模型是否能够降低不稳定时间段或低质量区域的影响，并突出更可靠的判别线索。}}{12}{}\protected@file@percent }
\newlabel{fig:attention_reliability_zh}{{4}{12}{}{figure.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces RT-MRCPNet 消融实验。ACC 表示准确率，AUC 表示受试者工作特征曲线下面积，所有指标均以百分比（\%）报告。}}{12}{}\protected@file@percent }
